# Copy this file to .env and fill in your own values

FINNHUB_API_KEY=your_finnhub_key_here
TWELVE_DATA_API_KEY=your_twelve_data_key_here
FRED_API_KEY=your_fred_api_key_here
MASSIVE_API_KEY=              # optional — leave blank if unused

# Required by the SEC to access EDGAR filings.
# Use your real name and email — the SEC blocks generic/fake values.
SEC_USER_AGENT=Your Name youremail@example.com

PROVIDER_VERBOSE=false
