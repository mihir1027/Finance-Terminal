# Copy this file to .env and fill in your own values

FINNHUB_API_KEY=your_finnhub_key_here
TWELVE_DATA_API_KEY=your_twelve_data_key_here
FRED_API_KEY=your_fred_api_key_here
MASSIVE_API_KEY=              # optional — leave blank if unused

# Required by the SEC to access EDGAR filings.
# Use your real name and email — the SEC blocks generic/fake values.
SEC_USER_AGENT=Your Name youremail@example.com

PROVIDER_VERBOSE=false

# Optional enrichment APIs — leave blank if unused
TIINGO_API_KEY=               # tiingo.com — 100 req/day free; adds to quote fallback chain
ALPHA_VANTAGE_API_KEY=        # alphavantage.co — 5 req/min free; chart indicators + quote fallback
CURRENCY_LAYER_API_KEY=       # currencylayer.com — 100 req/day free; primary FX source
MARKETSTACK_API_KEY=          # marketstack.com — ~1000 req/month free; global equity fallback
EODHD_API_KEY=                # eodhd.com — 20 req/day free; global ticker fallback
FIXER_API_KEY=                # fixer.io — 100 req/month free; historical forex rates
USDA_FAS_API_KEY=             # apps.fas.usda.gov — free; agricultural export/production data
